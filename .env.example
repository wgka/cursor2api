# 复制为 .env 后，docker compose 会自动读取这些变量
# cp .env.example .env

# 容器端口 / 宿主机映射
HOST_PORT=3010
PORT=3010
NODE_ENV=production
TIMEOUT=120

# 可选：切换构建基础镜像
# DOCKER_NODE_IMAGE=node:22-alpine

# 可选：国内机器构建时可改为镜像源
# NPM_REGISTRY=https://registry.npmmirror.com

# 可选：如需与宿主机文件权限对齐，可改 UID/GID
# APP_UID=1001
# APP_GID=1001
